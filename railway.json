{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "watchPatterns": ["src/**", "package.json", "package-lock.json", "server.js", "*.ts", "*.js"]
  },
  "deploy": {
    "startCommand": "cd backend && npm ci && npm run build && npm start",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 10,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
